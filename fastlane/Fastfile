default_platform(:ios)

platform :ios do

  # ──────────────────────────────────────────────
  # BUILD & UPLOAD
  # ──────────────────────────────────────────────

  desc "Build, archive, and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: "B9UDCQDB4M",
      issuer_id: "a1706321-12dc-4e95-8895-d0ddd2d63d11",
      key_filepath: "fastlane/AuthKey_B9UDCQDB4M.p8"
    )

    increment_build_number(
      xcodeproj: "BoatNav.xcodeproj"
    )

    build_app(
      project: "BoatNav.xcodeproj",
      scheme: "BoatNav",
      clean: true,
      output_directory: "./build",
      output_name: "BoatNav.ipa",
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: "3TZFTAC2SR"
      },
      xcodebuild_formatter: "",
      xcargs: "-allowProvisioningUpdates -authenticationKeyPath '#{File.expand_path("AuthKey_B9UDCQDB4M.p8", __dir__)}' -authenticationKeyID B9UDCQDB4M -authenticationKeyIssuerID a1706321-12dc-4e95-8895-d0ddd2d63d11"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Full release: build + upload + metadata to App Store"
  lane :release do
    increment_build_number(
      xcodeproj: "BoatNav.xcodeproj"
    )

    build_app(
      project: "BoatNav.xcodeproj",
      scheme: "BoatNav",
      clean: true,
      output_directory: "./build",
      output_name: "BoatNav.ipa",
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: "3TZFTAC2SR"
      }
    )

    upload_to_app_store(
      api_key_path: "fastlane/api_key.json",
      skip_metadata: false,
      skip_screenshots: false,
      force: true,
      submit_for_review: false,       # set to true when ready
      automatic_release: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  # ──────────────────────────────────────────────
  # METADATA ONLY (no build)
  # ──────────────────────────────────────────────

  desc "Sync metadata and screenshots to App Store Connect (no build)"
  lane :metadata do
    upload_to_app_store(
      api_key_path: "fastlane/api_key.json",
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: false,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  # ──────────────────────────────────────────────
  # CERTIFICATES (code signing)
  # ──────────────────────────────────────────────

  desc "Sync certificates and provisioning profiles"
  lane :certs do
    match(
      type: "appstore",
      app_identifier: "nl.boatnav.app",
      api_key_path: "fastlane/api_key.json"
    )
  end

end
